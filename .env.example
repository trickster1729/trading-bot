# ── Mode ────────────────────────────────────────────────────────────────────────
# shadow = historical replay + paper PnL (Phase 1)
# paper  = live prices + paper orders  (Phase 2)
# live   = live prices + real orders   (Phase 3+)
MODE=shadow

# ── Logging ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/trading.log

# ── Alpaca (stocks / options) ────────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # switch to live URL in Phase 3

# ── Binance (crypto) ────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_key_here
BINANCE_SECRET_KEY=your_binance_secret_here
BINANCE_TESTNET=true    # set false in Phase 3

# ── Risk limits ──────────────────────────────────────────────────────────────────
MAX_POSITION_PCT=0.02   # max 2% of account per trade
MAX_DRAWDOWN_PCT=0.10   # halt trading if drawdown > 10%
